PORT=8081
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db
DB_SSLMODE=disable

# Redis Configuration (Caches & Blacklists)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

# Token Expiry Settings
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# RSA Keypair Paths
RSA_PRIVATE_KEY_PATH=certs/private.key
RSA_PUBLIC_KEY_PATH=certs/public.key
