                        "description": "Variables mapping",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handler.CompilePromptReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Returns compiled_prompt and token_estimate",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
