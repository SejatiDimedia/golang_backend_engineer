PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=file_db
DB_SSLMODE=disable

# MinIO / S3 Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=user-files
MINIO_PRESIGNED_EXPIRY_MINUTES=15

# Authentication Secrets
JWT_SECRET=super_secret_file_management_signing_key_change_me
JWT_EXPIRY_HOURS=24
