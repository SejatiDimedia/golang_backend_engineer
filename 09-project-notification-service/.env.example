PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=notification_db
DB_SSLMODE=disable

# Redis Configuration (Message Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# Concurrency & Simulation Settings
WORKER_CONCURRENCY=5
PROVIDER_FAILURE_RATE=0.3

# Authentication Secrets
JWT_SECRET=super_secret_notification_signing_key_change_me
JWT_EXPIRY_HOURS=24
